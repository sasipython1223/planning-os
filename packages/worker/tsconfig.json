{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "protocol": ["../protocol/src/index.ts"],
      "protocol/kernel": ["../protocol/src/kernel.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "worker.ts"]
}